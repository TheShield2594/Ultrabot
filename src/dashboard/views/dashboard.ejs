<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — UltraBot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="mesh-bg"><div class="grid"></div><div class="blob-3"></div></div>

    <header class="topbar">
        <a href="/" class="brand" style="text-decoration:none;color:inherit;">
            <span class="brand-mark"></span>
            <span>UltraBot</span>
        </a>
        <div class="topbar-right">
            <div class="user-chip">
                <% if (user.avatar) { %>
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="">
                <% } else { %>
                    <img src="https://cdn.discordapp.com/embed/avatars/0.png" alt="">
                <% } %>
                <span><%= user.username %></span>
            </div>
            <a href="/auth/logout" class="btn btn-sm">Logout</a>
        </div>
    </header>

    <main class="container">
        <div class="page-head">
            <h1>Your Servers</h1>
            <p>Pick a server to configure UltraBot. You'll only see servers where you have <strong>Manage Server</strong> and the bot is present.</p>
        </div>

        <% if (guilds.length === 0) { %>
            <div class="empty-state">
                <h3>No matching servers yet</h3>
                <p>Invite UltraBot to a server you manage, then refresh this page.</p>
                <div style="margin-top:1.25rem;">
                    <a href="/" class="btn btn-sm">Back home</a>
                </div>
            </div>
        <% } else { %>
            <div class="guild-grid">
                <% guilds.forEach(guild => { %>
                    <div class="guild-card">
                        <% if (guild.icon) { %>
                            <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" alt="<%= guild.name %>" class="guild-icon">
                        <% } else { %>
                            <div class="guild-icon guild-icon-fallback"><%= guild.name.charAt(0).toUpperCase() %></div>
                        <% } %>
                        <div class="guild-name"><%= guild.name %></div>
                        <a href="/dashboard/guild/<%= guild.id %>" class="btn btn-primary btn-sm">Manage</a>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </main>
</body>
</html>
