<script>
(function() {
    var heatmap = document.getElementById('insights-heatmap');
    if (!heatmap) return;
    var days = ['MON','TUE','WED','THU','FRI','SAT','SUN'];
    var intensity = function(d, h) {
        var base = 0;
        if (h >= 16 && h <= 23) base = 0.5 + 0.4 * Math.sin((h - 16) / 7 * Math.PI);
        else if (h >= 11 && h <= 15) base = 0.3;
        else if (h >= 0 && h < 6) base = 0.05;
        if (d >= 5) base += 0.18;
        if (d === 5 && h === 21) base = 1;
        return Math.max(0, Math.min(1, base));
    };
    var colorFor = function(v) {
        if (v < 0.1) return '#2a241e';
        var a = (0.15 + v * 0.85).toFixed(2);
        return 'rgba(217,119,66,' + a + ')';
    };
    var html = '<div></div>';
    [0, 3, 6, 9, 12, 15, 18, 21].forEach(function(h) {
        html += '<div class="h" style="grid-column:span 3">' + String(h).padStart(2, '0') + '</div>';
    });
    days.forEach(function(d, di) {
        html += '<div class="lbl">' + d + '</div>';
        for (var h = 0; h < 24; h++) {
            var v = intensity(di, h);
            html += '<div class="cell" style="background:' + colorFor(v) + '"></div>';
        }
    });
    heatmap.innerHTML = html;
})();
</script>
