# Discord Bot
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Database (use service name "mongodb" when running via Docker Compose)
MONGODB_URI=mongodb://mongodb:27017/ultrabot

# Dashboard
DASHBOARD_PORT=3000
DASHBOARD_URL=http://localhost:3000
SESSION_SECRET=replace_with_random_32_char_string

# AI (optional)
OPENAI_API_KEY=sk-your_openai_key_here
GEMINI_API_KEY=AIza_your_gemini_key_here

# Music (optional)
YOUTUBE_COOKIE=your_youtube_cookie_if_needed

NODE_ENV=production
